#!/usr/bin/env bash

set -Eeuo pipefail

OLLAMA_NAMESPACE="ai"
OLLAMA_DEPLOYMENT="ollama"
OLLAMA_SELECTOR="app=ollama"

WORKSPACE_NAMESPACE="jupyter"
CODE_SERVER_DEPLOYMENT="code-server"
JUPYTER_DEPLOYMENT="jupyter"
JUPYTER_SELECTOR="app=jupyter"

TIMEOUT="180s"

info() {
    printf '\n\033[1;34m%s\033[0m\n' "$1"
}

success() {
    printf '\033[1;32m✔ %s\033[0m\n' "$1"
}

warning() {
    printf '\033[1;33m⚠ %s\033[0m\n' "$1"
}

error() {
    printf '\033[1;31m✘ %s\033[0m\n' "$1" >&2
}

require_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        error "No se ha encontrado el comando '$1'."
        exit 1
    fi
}

check_cluster() {
    if ! kubectl cluster-info >/dev/null 2>&1; then
        error "No se puede conectar con el clúster Kubernetes."
        exit 1
    fi
}

scale_deployment() {
    local namespace="$1"
    local deployment="$2"
    local replicas="$3"

    kubectl scale deployment "$deployment" \
        --namespace "$namespace" \
        --replicas "$replicas" >/dev/null
}

wait_for_rollout() {
    local namespace="$1"
    local deployment="$2"

    kubectl rollout status deployment/"$deployment" \
        --namespace "$namespace" \
        --timeout="$TIMEOUT"
}

wait_for_pods_deleted() {
    local namespace="$1"
    local selector="$2"

    if kubectl get pods \
        --namespace "$namespace" \
        --selector "$selector" \
        --no-headers 2>/dev/null | grep -q .; then

        kubectl wait \
            --namespace "$namespace" \
            --for=delete pod \
            --selector "$selector" \
            --timeout="$TIMEOUT"
    fi
}

ensure_code_server() {
    info "Comprobando code-server..."

    scale_deployment \
        "$WORKSPACE_NAMESPACE" \
        "$CODE_SERVER_DEPLOYMENT" \
        1

    wait_for_rollout \
        "$WORKSPACE_NAMESPACE" \
        "$CODE_SERVER_DEPLOYMENT"

    success "code-server está disponible."
}

enable_copilot_mode() {
    info "Activando modo COPILOT..."

    ensure_code_server

    info "Deteniendo Jupyter..."
    scale_deployment \
        "$WORKSPACE_NAMESPACE" \
        "$JUPYTER_DEPLOYMENT" \
        0

    wait_for_pods_deleted \
        "$WORKSPACE_NAMESPACE" \
        "$JUPYTER_SELECTOR"

    success "Jupyter está detenido y la GPU ha sido liberada."

    info "Iniciando Ollama..."
    scale_deployment \
        "$OLLAMA_NAMESPACE" \
        "$OLLAMA_DEPLOYMENT" \
        1

    wait_for_rollout \
        "$OLLAMA_NAMESPACE" \
        "$OLLAMA_DEPLOYMENT"

    success "Ollama está disponible."
    success "Modo COPILOT activado."
}

enable_train_mode() {
    info "Activando modo TRAIN..."

    ensure_code_server

    info "Deteniendo Ollama..."
    scale_deployment \
        "$OLLAMA_NAMESPACE" \
        "$OLLAMA_DEPLOYMENT" \
        0

    wait_for_pods_deleted \
        "$OLLAMA_NAMESPACE" \
        "$OLLAMA_SELECTOR"

    success "Ollama está detenido y la GPU ha sido liberada."

    info "Iniciando Jupyter..."
    scale_deployment \
        "$WORKSPACE_NAMESPACE" \
        "$JUPYTER_DEPLOYMENT" \
        1

    wait_for_rollout \
        "$WORKSPACE_NAMESPACE" \
        "$JUPYTER_DEPLOYMENT"

    success "Jupyter está disponible."
    success "Modo TRAIN activado."
}

enable_stop_mode() {
    info "Deteniendo servicios con GPU..."

    scale_deployment \
        "$OLLAMA_NAMESPACE" \
        "$OLLAMA_DEPLOYMENT" \
        0

    scale_deployment \
        "$WORKSPACE_NAMESPACE" \
        "$JUPYTER_DEPLOYMENT" \
        0

    wait_for_pods_deleted \
        "$OLLAMA_NAMESPACE" \
        "$OLLAMA_SELECTOR"

    wait_for_pods_deleted \
        "$WORKSPACE_NAMESPACE" \
        "$JUPYTER_SELECTOR"

    ensure_code_server

    success "Ollama y Jupyter están detenidos."
    success "code-server permanece disponible."
}

deployment_replicas() {
    local namespace="$1"
    local deployment="$2"

    kubectl get deployment "$deployment" \
        --namespace "$namespace" \
        -o jsonpath='{.status.readyReplicas}' 2>/dev/null || true
}

deployment_desired_replicas() {
    local namespace="$1"
    local deployment="$2"

    kubectl get deployment "$deployment" \
        --namespace "$namespace" \
        -o jsonpath='{.spec.replicas}' 2>/dev/null || true
}

service_status() {
    local namespace="$1"
    local deployment="$2"

    local desired
    local ready

    desired="$(deployment_desired_replicas "$namespace" "$deployment")"
    ready="$(deployment_replicas "$namespace" "$deployment")"

    desired="${desired:-0}"
    ready="${ready:-0}"

    if [[ "$desired" == "0" ]]; then
        printf "Stopped"
    elif [[ "$ready" == "$desired" ]]; then
        printf "Running"
    else
        printf "Starting"
    fi
}

show_status() {
    local ollama_status
    local jupyter_status
    local code_server_status
    local mode

    ollama_status="$(
        service_status \
            "$OLLAMA_NAMESPACE" \
            "$OLLAMA_DEPLOYMENT"
    )"

    jupyter_status="$(
        service_status \
            "$WORKSPACE_NAMESPACE" \
            "$JUPYTER_DEPLOYMENT"
    )"

    code_server_status="$(
        service_status \
            "$WORKSPACE_NAMESPACE" \
            "$CODE_SERVER_DEPLOYMENT"
    )"

    if [[ "$ollama_status" == "Running" &&
          "$jupyter_status" == "Stopped" ]]; then
        mode="COPILOT"
    elif [[ "$ollama_status" == "Stopped" &&
            "$jupyter_status" == "Running" ]]; then
        mode="TRAIN"
    elif [[ "$ollama_status" == "Stopped" &&
            "$jupyter_status" == "Stopped" ]]; then
        mode="STOP"
    else
        mode="TRANSITION / UNKNOWN"
    fi

    printf '\nCloud AI Workspace\n'
    printf '==================\n\n'
    printf 'Mode: %s\n\n' "$mode"
    printf '%-16s %s\n' "code-server" "$code_server_status"
    printf '%-16s %s\n' "Ollama" "$ollama_status"
    printf '%-16s %s\n' "Jupyter" "$jupyter_status"

    if [[ "$ollama_status" == "Running" ]]; then
        printf '\nOllama models loaded:\n'

        kubectl exec \
            --namespace "$OLLAMA_NAMESPACE" \
            deployment/"$OLLAMA_DEPLOYMENT" \
            -- ollama ps 2>/dev/null || warning \
            "No se ha podido consultar ollama ps."
    fi
}

show_help() {
    cat <<'EOF'
Uso:

  ./scripts/workspace copilot
  ./scripts/workspace train
  ./scripts/workspace stop
  ./scripts/workspace status

Modos:

  copilot   Inicia Ollama y detiene Jupyter.
  train     Detiene Ollama e inicia Jupyter.
  stop      Detiene Ollama y Jupyter.
  status    Muestra el estado actual.
EOF
}

main() {
    require_command kubectl
    check_cluster

    case "${1:-}" in
        copilot)
            enable_copilot_mode
            ;;
        train)
            enable_train_mode
            ;;
        stop)
            enable_stop_mode
            ;;
        status)
            show_status
            ;;
        help|--help|-h|"")
            show_help
            ;;
        *)
            error "Modo desconocido: $1"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
